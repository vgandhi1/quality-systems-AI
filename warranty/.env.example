# ── Copy to .env and fill in values. Never commit .env ──

# ── Application ──
WARRANTY_ENVIRONMENT=development

# ── API server ──
# Default bind is localhost only (not reachable from LAN).
WARRANTY_API_HOST=127.0.0.1
WARRANTY_API_PORT=8080

# API key — REQUIRED when:
#   • WARRANTY_API_HOST is 0.0.0.0 (LAN access via portproxy), OR
#   • WARRANTY_ENVIRONMENT=production
# Optional on 127.0.0.1 dev (open access when unset).
#
# Generate a key:
#   openssl rand -hex 32
#
# Clients send:  X-API-Key: <your-key>
# Swagger /docs: use Authorize if you add the key (or call curl with header).
# WARRANTY_API_KEY=

# Browser UI on another machine (optional). Comma-separated origins only — no wildcards.
# WARRANTY_CORS_ORIGINS=http://192.168.1.10:3000,http://localhost:3000

# ── Workspace ──
# WARRANTY_WORKSPACE=./workspace

# ── Policy search (keyword | qdrant) ──
WARRANTY_POLICY_BACKEND=keyword
# WARRANTY_QDRANT_URL=http://localhost:6333

# ── LLM provider (anthropic | ollama) ──
AGENTFORGE_LLM_PROVIDER=anthropic
# AGENTFORGE_MODEL=claude-opus-4-8
# ANTHROPIC_API_KEY=

# Agent tool loops: temperature 0 for deterministic structured extraction (08-AI-SECURITY).
# WARRANTY_LLM_TEMPERATURE=0
# Per-call wall-clock timeout in seconds (agent loop safety).
# WARRANTY_LLM_TIMEOUT_SECONDS=30
# Token budgets — enforced before each LLM call (rough char/4 estimate).
# MAX_CONTEXT_TOKENS=8000
# MAX_COMPLETION_TOKENS=4000
# MAX_INPUT_TOKENS=8000

# ── Ollama ──
# AGENTFORGE_OLLAMA_HOST=http://127.0.0.1:11434
# AGENTFORGE_OLLAMA_MODEL=qwen2.5:7b-instruct

# ── QualityMind escalation (optional — POST /escalate/execute) ──
# QUALITYMIND_BASE_URL=http://localhost:8000
# QUALITYMIND_API_KEY=
